DATABASE_URL="file:./dev.db"
JWT_SECRET="zingte-dev-secret-change-in-production"
NEXT_PUBLIC_APP_NAME="Zingte API Hub"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Email (SMTP) — required for real emails in production
# Leave SMTP_HOST empty for local dev (links print in terminal + show in UI)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@yourdomain.com"
EMAIL_FROM_NAME="Zingte API Hub"

# Must match where the app runs (verification links use this URL)
# Local: http://localhost:3000

# Cron job secret for /api/cron/subscriptions (optional)
CRON_SECRET="change-me-in-production"
